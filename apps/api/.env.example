# ============================================================================
# Backend — Aura API
# Copia este archivo a .env.local y completá los valores.
# Ver docs/devops/environments.md para descripción de cada variable.
# ============================================================================

# App
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Database (dev compose maps host 5433 → container 5432 to avoid conflicts)
DB_URL=postgresql+asyncpg://aura:aura@localhost:5435/aura
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (dev compose maps host 6380 → container 6379)
REDIS_URL=redis://localhost:6385/0

# JWT
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# OAuth (dejar vacío en dev hasta tener credenciales)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8000/v1/auth/oauth/google/callback
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common
OAUTH_MICROSOFT_REDIRECT_URL=http://localhost:8000/v1/auth/oauth/microsoft/callback

# R2 / S3-compatible (MinIO en dev)
R2_ACCOUNT_ID=dev
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=aura-media
R2_PUBLIC_BASE_URL=http://localhost:9000/aura-media
R2_REGION=auto
R2_ENDPOINT_URL=http://localhost:9000

# Payments (dejar vacío hasta tener credenciales)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Email
RESEND_API_KEY=
EMAIL_FROM=Aura <hola@aura.local>
EMAIL_SUPPORT=soporte@aura.local

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
LOG_LEVEL=INFO

# Admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@aura.local
BOOTSTRAP_ADMIN_PASSWORD=changeme-on-first-login
