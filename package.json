{
  "name": "aura",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "lint:web": "npm --workspace apps/web run lint",
    "test:web": "npm --workspace apps/web run test",
    "compose:dev:up": "docker compose -f infra/compose/docker-compose.dev.yml up -d",
    "compose:dev:down": "docker compose -f infra/compose/docker-compose.dev.yml down"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
